<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<lab name="WORKSHOP BGP" version="1" scripttimeout="300" lock="0" author="Gustavo Kalau Treinamento">
  <description>LAB utilizado no Workshop de BGP transmitido no Youtube.com/gustavokalau nos dias 11, 12 e 13 de Julho de 2022.</description>
  <body>Configuração de iBGP x eBGP;
Propagação de prefixos;
Ajustando a publicação entre iBGP;
Peer-group;
Router Reflector;
Loopback em configuração iBGP;
Engenharia de tráfego para iniciantes;
Route-map, prefix list e AS-Path</body>
